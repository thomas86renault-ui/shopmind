{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/ecouteurs-sans-fil", "destination": "/ecouteurs-sans-fil.html" },
    { "source": "/robot-aspirateur", "destination": "/robot-aspirateur.html" },
